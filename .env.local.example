# Atleast one of them Manadatory
GOOGLE_AI_API_KEY=your_google_ai_studio_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Not Mandatory
AI_PRIMARY_PROVIDER=gemini, claude, or openai — put this provider first in fallback chain
AI_FALLBACK_CHAIN=Comma-separated model keys, e.g. gemini-2.5-flash,claude-haiku-3.5
GEMINI_RATE_LIMIT=Requests/minute for Gemini (default: 60)
CLAUDE_RATE_LIMIT=Requests/minute for Claude (default: 50)
OPENAI_RATE_LIMIT=Requests/minute for OpenAI (default: 60)